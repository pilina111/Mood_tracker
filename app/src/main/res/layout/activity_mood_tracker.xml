<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Mood_Tracker">

    <Button
        android:id="@+id/button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="23dp"
        android:layout_marginTop="27dp"
        android:text="back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/title_input"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="120dp"
        android:layout_marginTop="144dp"
        android:text="TextView"
        android:textSize="20sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/mood"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="23dp"
        android:layout_marginTop="129dp"
        android:text="How are you today?"
        android:textSize="20sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/button" />

    <Button
        android:id="@+id/next"
        android:layout_width="95dp"
        android:layout_height="52dp"
        android:layout_marginStart="280dp"
        android:layout_marginBottom="104dp"
        android:text="next"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/joy"
        android:layout_width="110dp"
        android:layout_height="106dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:scaleType="centerInside"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/mood"
        android:contentDescription="choose joy"
        app:srcCompat="@drawable/joy" />

    <ImageButton
        android:id="@+id/good"
        android:layout_width="110dp"
        android:layout_height="106dp"
        android:layout_marginTop="20dp"
        android:scaleType="centerInside"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/mood"
        android:contentDescription="choose good"
        app:srcCompat="@drawable/good" />

    <ImageButton
        android:id="@+id/ok"
        android:layout_width="110dp"
        android:layout_height="106dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:scaleType="centerInside"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/mood"
        android:contentDescription="choose ok"
        app:srcCompat="@drawable/ok" />

    <ImageButton
        android:id="@+id/bad"
        android:layout_width="110dp"
        android:layout_height="106dp"
        android:layout_marginStart="60dp"
        android:layout_marginTop="150dp"
        android:scaleType="centerInside"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/mood"
        android:contentDescription="choose bad"
        app:srcCompat="@drawable/bad" />

    <ImageButton
        android:id="@+id/depressed"
        android:layout_width="110dp"
        android:layout_height="106dp"
        android:layout_marginTop="150dp"
        android:layout_marginEnd="60dp"
        android:scaleType="centerInside"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/mood"
        android:contentDescription="choose depressed"
        app:srcCompat="@drawable/depessed" />


</androidx.constraintlayout.widget.ConstraintLayout>